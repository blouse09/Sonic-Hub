local function pressE()
    -- Yöntem 1: Delta uyumlu keypress/keyrelease (en güvenli)
    pcall(function()
        if keypress then
            keypress(0x45) -- E tuşu
            task.wait(0.05)
            keyrelease(0x45)
            return
        end
    end)
    -- Yöntem 2: VirtualInputManager (Xeno/Synapse)
    pcall(function()
        local vim = game:GetService("VirtualInputManager")
        vim:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.05)
        vim:SendKeyEvent(false, Enum.KeyCode.E, false, game)
    end)
    -- Yöntem 3: ProximityPrompt tetikleme (tüm executorlar)
    pcall(function()
        if Character and Character:FindFirstChild("HumanoidRootPart") then
            local hrp = Character.HumanoidRootPart
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") then
                    local dist = (obj.Parent.Position - hrp.Position).Magnitude
                    if dist < 20 then
                        pcall(function()
                            if fireproximityprompt then
                                fireproximityprompt(obj)
                            else
                                obj:InputHoldBegin()
                                task.wait(0.1)
                                obj:InputHoldEnd()
                            end
                        end)
                    end
                end
            end
        end
    end)
    -- Yöntem 4: Karakterdeki mevcut tool'u aktive et (backpack'ten dumbbell equiplemeye ÇALIŞMA)
    pcall(function()
        if Character then
            -- Zaten elinde tool varsa sadece onu aktive et
            local hasTool = false
            for _, tool in pairs(Character:GetChildren()) do
                if tool:IsA("Tool") then
                    pcall(function() tool:Activate() end)
                    hasTool = true
                end
            end
            -- Elinde tool YOKSA backpack'ten sadece ağırlık al (dumbbell DEĞİL)
            if not hasTool then
                local backpack = LP:FindFirstChild("Backpack")
                if backpack then
                    for _, tool in pairs(backpack:GetChildren()) do
                        if tool:IsA("Tool") then
                            local n = tool.Name:lower()
                            -- Sadece bar/squat/lift/jungle equip et, dumbbell HAYIR
                            if (n:find("bar") or n:find("squat") or n:find("lift") or n:find("jungle")) and not n:find("dumbbell") and not n:find("dumb") then
                                pcall(function() Humanoid:EquipTool(tool) end)
                                task.wait(0.1)
                                pcall(function() tool:Activate() end)
                                break -- Sadece bir tane equip et
                            end
                        end
                    end
                end
            end
        end
    end)
end

