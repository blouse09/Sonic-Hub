-- Anti-Lag toggle
States.AntiLagEnabled = false
local antiLagConns = {}

addToggle(Pages.Misc, "🛡 Anti-Lag (Performans Arttır)", false, function(v)
    States.AntiLagEnabled = v
    if v then
        pcall(function()
            -- Partiçülleri kapat
            local lighting = game:GetService("Lighting")
            lighting.GlobalShadows = false
            lighting.FogEnd = 9e9
            
            -- PlayerGui'deki gereksiz efektleri kapat
            local pg = LP:FindFirstChild("PlayerGui")
            if pg then
                for _, gui in pairs(pg:GetDescendants()) do
                    pcall(function()
                        if gui:IsA("ParticleEmitter") then
                            gui.Enabled = false
                        elseif gui:IsA("Trail") then
                            gui.Enabled = false
                        elseif gui:IsA("Beam") then
                            gui.Enabled = false
                        end
                    end)
                end
            end
            
            -- Workspace'teki parçacık ve efektleri kapat
            for _, obj in pairs(workspace:GetDescendants()) do
                pcall(function()
                    if obj:IsA("ParticleEmitter") then
                        obj.Enabled = false
                    elseif obj:IsA("Trail") then
                        obj.Enabled = false
                    elseif obj:IsA("Beam") then
                        obj.Enabled = false
                    elseif obj:IsA("Fire") then
                        obj.Enabled = false
                    elseif obj:IsA("Smoke") then
                        obj.Enabled = false
                    elseif obj:IsA("Sparkles") then
                        obj.Enabled = false
                    end
                end)
            end
            
            -- Yeni eklenen efektleri de kapat
            local conn = workspace.DescendantAdded:Connect(function(obj)
                if not States.AntiLagEnabled then return end
                pcall(function()
                    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                        obj.Enabled = false
                    end
                end)
            end)
            table.insert(antiLagConns, conn)
            
            -- Render kalitesini düşür
            pcall(function()
                settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
            end)
        end)
        
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🛡 Anti-Lag",
            Text = "Anti-Lag aktif! Parçacıklar, efektler ve gölgeler kapatıldı.",
            Duration = 4
        })
    else
        -- Kapatırken oyunu bozma - efektleri geri aç
        for _, conn in pairs(antiLagConns) do
            pcall(function() conn:Disconnect() end)
        end
        antiLagConns = {}
        
        pcall(function()
            local lighting = game:GetService("Lighting")
            lighting.GlobalShadows = true
            
            -- Parçacıkları geri aç
            for _, obj in pairs(workspace:GetDescendants()) do
                pcall(function()
                    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                        obj.Enabled = true
                    end
                end)
            end
            
            -- Render kalitesini geri yükselt
            pcall(function()
                settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic
            end)
        end)
        
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🛡 Anti-Lag",
            Text = "Anti-Lag kapatıldı. Efektler geri açıldı.",
            Duration = 3
        })
    end
end)

