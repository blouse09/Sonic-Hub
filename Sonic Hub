local LP = Players.LocalPlayer
local Character = LP.Character or LP.CharacterAdded:Wait()
local Humanoid = Character:WaitForChild("Humanoid")

LP.CharacterAdded:Connect(function(c)
    Character = c
    Humanoid = c:WaitForChild("Humanoid")
    -- Death fix: Reset visual states so game doesn't break on respawn
    pcall(function()
        States.HideVisuals = false
        States.HideAllFrames = false
        States.NoClip = false
        -- Disconnect old hide connections
        if hideConnections then
            for _, conn in pairs(hideConnections) do
                pcall(function() conn:Disconnect() end)
            end
            hideConnections = {}
        end
        -- Disconnect old frame hide connections
        if hideFrameConnections then
            for _, conn in pairs(hideFrameConnections) do
                pcall(function() conn:Disconnect() end)
            end
            hideFrameConnections = {}
        end
        -- Reset transparency on new character
        for _, part in pairs(c:GetDescendants()) do
            pcall(function()
                if part:IsA("BasePart") then
                    part.LocalTransparencyModifier = 0
                    part.CanCollide = true
                end
            end)
        end
    end)
end)

