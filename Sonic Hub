-- Snack/Boost yeme fonksiyonu - AGGRESSIVE FORCE EAT
-- Agirlik kullanirken bile zorla ekipleyip yedirtir
-- Elinden dusurse tekrar takar, yiyene kadar tiklar
local function forceEatSnack(snackName)
    local eaten = false
    local maxAttempts = 60 -- Max 60 deneme (~12 saniye)

    pcall(function()
        -- Mevcut kullanilan tool'u kaydet (sonra geri takmak icin)
        local currentTool = nil
        if Character then
            for _, obj in pairs(Character:GetChildren()) do
                if obj:IsA("Tool") and obj.Name ~= snackName then
                    currentTool = obj
                    break
                end
            end
        end

        -- Tool'u bul (Backpack veya Character'da)
        local function findSnackTool()
            local backpack = LP:FindFirstChild("Backpack")
            if backpack then
                local t = backpack:FindFirstChild(snackName)
                if t and t:IsA("Tool") then return t end
            end
            if Character then
                local t = Character:FindFirstChild(snackName)
                if t and t:IsA("Tool") then return t end
            end
            return nil
        end

        local tool = findSnackTool()
        if not tool then return end

        -- Once mevcut tool'u birak
        pcall(function() Humanoid:UnequipTools() end)
        task.wait(0.15)

        -- AGGRESSIVE FORCE EAT LOOP
        -- Heartbeat ile her frame kontrol et:
        -- 1) Tool envanterde mi? Eline al
        -- 2) Tool elde mi? Activate + Click
        -- 3) Tool yok oldu mu? Yendi = basarili
        local forceConn = nil
        local attempts = 0
        local clickCounter = 0

        forceConn = RunService.Heartbeat:Connect(function()
            if eaten or attempts >= maxAttempts then
                if forceConn then forceConn:Disconnect(); forceConn = nil end
                return
            end
            attempts = attempts + 1

            pcall(function()
                local t = findSnackTool()
                if not t then
                    -- Tool artik yok = yedi!
                    eaten = true
                    if forceConn then forceConn:Disconnect(); forceConn = nil end
                    return
                end

                -- Tool backpack'te ise zorla eline al
                if t.Parent ~= Character then
                    pcall(function() Humanoid:UnequipTools() end)
                    pcall(function() Humanoid:EquipTool(t) end)
                end

                -- Tool elde ise surekli tikla/activate et
                if t.Parent == Character then
                    clickCounter = clickCounter + 1
                    -- Her 3 frame'de bir activate (spam ama cok agresif olmadan)
                    if clickCounter % 3 == 0 then
                        pcall(function() t:Activate() end)
                        pcall(function() mouse1click() end)
                    end
                    -- Her 6 frame'de ekstra click
                    if clickCounter % 6 == 0 then
                        pcall(function() t:Activate() end)
                    end
                end
            end)
        end)

        -- Ayrica paralel loop ile de zorla (heartbeat'e ek)
        spawn(function()
            local spawnAttempts = 0
            while not eaten and spawnAttempts < maxAttempts do
                spawnAttempts = spawnAttempts + 1
                pcall(function()
                    local t = findSnackTool()
                    if not t then
                        eaten = true
                        return
                    end

                    -- Zorla eline al
                    if t.Parent ~= Character then
                        pcall(function() Humanoid:UnequipTools() end)
                        task.wait(0.05)
                        pcall(function() Humanoid:EquipTool(t) end)
                    end

                    -- Activate + Click
                    pcall(function() t:Activate() end)
                    task.wait(0.05)
                    pcall(function() t:Activate() end)
                    pcall(function() mouse1click() end)
                end)
                task.wait(0.2)
            end

            -- Temizlik
            if forceConn then forceConn:Disconnect(); forceConn = nil end
        end)

        -- Sonucu bekle (max 12 saniye)
        local waitTime = 0
        while not eaten and waitTime < 12 do
            task.wait(0.2)
            waitTime = waitTime + 0.2
        end

        -- Eski tool'u geri ekiple
        if currentTool and currentTool.Parent then
            pcall(function()
                task.wait(0.3)
                Humanoid:UnequipTools()
                task.wait(0.1)
                Humanoid:EquipTool(currentTool)
            end)
        end
    end)
    return eaten
end

-- Basit yeme fonksiyonu (manual butonlar icin - daha hafif)
local function eatSnack(snackName)
    return forceEatSnack(snackName)
end

local function eatProteinEgg()
    return forceEatSnack("Protein Egg")
end

