                floatDragging = false
                -- Bırakma efekti (büyüme)
                TweenService:Create(FloatingBtn, TweenInfo.new(0.15, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                    Size = UDim2.new(0, 56, 0, 56)
                }):Play()
            end
        end)
    end
end)

