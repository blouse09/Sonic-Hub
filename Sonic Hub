        pcall(function()
            local possibleNames = {"autoLiftEnabled", "autoLiftOwned", "hasAutoLift", "autoLift", "ownAutoLift", "autoLiftGamepass"}
            for _, name in ipairs(possibleNames) do
                local val = LP:FindFirstChild(name)
                if val then
                    pcall(function() val.Value = true end)
                else
                    pcall(function()
                        local newVal = Instance.new("BoolValue")
                        newVal.Name = name
                        newVal.Value = true
                        newVal.Parent = LP
                    end)
                end
            end
            local hs = LP:FindFirstChild("hiddenStats")
            if hs then
                for _, name in ipairs(possibleNames) do
                    local val = hs:FindFirstChild(name)
                    if val then pcall(function() val.Value = true end) end
                end
            end
        end)
        
        -- BYPASS 2: MarketplaceService Hook
        if not autoLiftGPHooked then
            pcall(function()
                local MPS = game:GetService("MarketplaceService")
                if hookfunction then
                    local old
                    old = hookfunction(MPS.UserOwnsGamePassAsync, function(self, userId, gamePassId)
                        if States.AutoLiftGamepass then return true end
                        return old(self, userId, gamePassId)
                    end)
                    autoLiftGPHooked = true
                end
            end)
        end
        
        -- BYPASS 3: GUI Auto Lift butonunu GÖRÜNÜR yap + tıkla
        pcall(function()
            local pg = LP:FindFirstChild("PlayerGui")
            if pg then
                for _, gui in pairs(pg:GetDescendants()) do
                    pcall(function()
                        local n = gui.Name:lower()
                        if n:find("autolift") or n:find("auto_lift") then
                            if gui:IsA("GuiObject") then gui.Visible = true end
                            if gui:IsA("TextButton") or gui:IsA("ImageButton") then
                                pcall(function() if firesignal then firesignal(gui.MouseButton1Click) end end)
                                pcall(function() gui.MouseButton1Click:Fire() end)
                            end
                        end
                        if gui.Parent and gui.Parent.Name:lower():find("autolift") then
                            if gui:IsA("GuiObject") then gui.Visible = true end
                        end
                    end)
                end
            end
        end)
        
        -- BYPASS 4: Remote event'ler
        pcall(function()
            local e = LP:FindFirstChild("muscleEvent")
            if e then
                e:FireServer("activateAutoLift")
                e:FireServer("autoLift")
                e:FireServer("toggleAutoLift")
                e:FireServer("setAutoLift", true)
            end
        end)
        
        -- ═══ Sürekli aktif tut (spawn loop - 2 sn aralık, hafif) ═══
        spawn(function()
            while States.AutoLiftGamepass do
                pcall(function()
                    local a = LP:FindFirstChild("autoLiftEnabled")
                    if a then a.Value = true end
                    local al2 = LP:FindFirstChild("autoLiftOwned")
                    if al2 then al2.Value = true end
                    local hs = LP:FindFirstChild("hiddenStats")
                    if hs then
                        local al = hs:FindFirstChild("autoLiftEnabled")
                        if al then al.Value = true end
                    end
                    local pg = LP:FindFirstChild("PlayerGui")
                    if pg then
                        for _, gui in pairs(pg:GetDescendants()) do
                            pcall(function()
                                if gui:IsA("GuiObject") and gui.Name:lower():find("autolift") then
                                    gui.Visible = true
                                end
                            end)
                        end
                    end
                end)
                task.wait(2)
            end
        end)
        
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🏋 Auto Lift",
            Text = "Auto Lift BYPASS aktive edildi! Bedava çalışıyor ✅",
            Duration = 4
        })
    else
        pcall(function()
            local a = LP:FindFirstChild("autoLiftEnabled")
            if a then a.Value = false end
        end)
        if autoLiftGPConn then pcall(function() autoLiftGPConn:Disconnect() end); autoLiftGPConn = nil end
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🏋 Auto Lift",
            Text = "Auto Lift kapatıldı.",
            Duration = 3
        })
    end
end)

