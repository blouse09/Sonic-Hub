-- PET EQUIP/UNEQUIP FONKSİYONLARI (ULTRA HIZLI)
------------------------------------------------------------
local function getEquipPetEvent()
    local rEvents = RS:FindFirstChild("rEvents")
    if rEvents then
        local ev = rEvents:FindFirstChild("equipPetEvent") or rEvents:FindFirstChild("petEquipEvent") or rEvents:FindFirstChild("equipPet")
        if ev then return ev end
    end
    local ev2 = LP:FindFirstChild("equipPetEvent") or LP:FindFirstChild("petEvent")
    return ev2
end

-- Tüm petleri çıkar (ultra hızlı)
local function unequipAllPets()
    pcall(function()
        local ev = getEquipPetEvent()
        if not ev then return end
        local eq = LP:FindFirstChild("equippedPets")
        if eq then
            for _, p in pairs(eq:GetChildren()) do
                pcall(function()
                    if p.Value then
                        if ev:IsA("RemoteEvent") then
                            ev:FireServer("unequipPet", p.Value)
                        elseif ev:IsA("RemoteFunction") then
                            ev:InvokeServer("unequipPet", p.Value)
                        end
                    end
                end)
            end
            task.wait(0.03)
        end
    end)
end

-- Belirli bir peti N tane tak (ultra hızlı)
local function equipPetByName(petName, count)
    local equipped = 0
    pcall(function()
        local ev = getEquipPetEvent()
        if not ev then return end
        local pf = LP:FindFirstChild("petsFolder")
        if not pf then return end
        
        for _, rarity in pairs(pf:GetChildren()) do
            if rarity:IsA("Folder") then
                for _, pet in pairs(rarity:GetChildren()) do
                    if equipped >= count then return end
                    if pet.Name == petName then
                        pcall(function()
                            if ev:IsA("RemoteEvent") then
                                ev:FireServer("equipPet", pet)
                            elseif ev:IsA("RemoteFunction") then
                                ev:InvokeServer("equipPet", pet)
                            end
                        end)
                        equipped = equipped + 1
                        task.wait(0.02) -- ultra hızlı: sadece 20ms bekleme
                    end
                end
            end
        end
    end)
    return equipped
end

-- Ultra hızlı pet swap: çıkar + tak (tek fonksiyon)
local function ultraFastPetSwap(petName, count)
    unequipAllPets()
    task.wait(0.03)
    return equipPetByName(petName, count)
end

