-- AUTO PROTEIN EGG (30 dakikada 1 yumurta - KESIN)
------------------------------------------------------------
local function eatOneEgg()
    local now = tick()
    -- 30 dakika gecmediyse YEME
    if (now - lastEggTime) < EGG_COOLDOWN then
        return false
    end
    
    local eaten = false
    pcall(function()
        -- YONTEM 1: Remote event ile ye (agirlik dusmuyor!)
        local rEvents = RS:FindFirstChild("rEvents")
        if rEvents then
            -- eatSnackEvent veya useItemEvent dene
            local snackEvent = rEvents:FindFirstChild("eatSnackEvent") or rEvents:FindFirstChild("useItemEvent")
            if snackEvent then
                pcall(function()
                    if snackEvent:IsA("RemoteEvent") then
                        snackEvent:FireServer("Protein Egg")
                    elseif snackEvent:IsA("RemoteFunction") then
                        snackEvent:InvokeServer("Protein Egg")
                    end
                end)
                eaten = true
                lastEggTime = tick()
            end
        end
        
        -- YONTEM 2: muscleEvent uzerinden dene
        if not eaten then
            local me = LP:FindFirstChild("muscleEvent")
            if me then
                pcall(function()
                    me:FireServer("eatSnack", "Protein Egg")
                    me:FireServer("useItem", "Protein Egg")
                end)
                eaten = true
                lastEggTime = tick()
            end
        end
        
        -- YONTEM 3: rEvents icerisindeki tum remote'lari dene
        if not eaten and rEvents then
            for _, remote in pairs(rEvents:GetChildren()) do
                if eaten then break end
                local rn = remote.Name:lower()
                if rn:find("snack") or rn:find("eat") or rn:find("use") or rn:find("item") or rn:find("food") then
                    pcall(function()
                        if remote:IsA("RemoteEvent") then
                            remote:FireServer("Protein Egg")
                        elseif remote:IsA("RemoteFunction") then
                            remote:InvokeServer("Protein Egg")
                        end
                    end)
                    eaten = true
                    lastEggTime = tick()
                end
            end
        end
        
        -- YONTEM 4: KALDIRILDI (tool equip yapmıyoruz - ağırlık düşürmesin)
    end)
    return eaten
end

