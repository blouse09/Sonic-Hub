local function startFarm()
    if States.FarmActive then return end
    if not States.SelectedWeight then
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Farm",
            Text = "Önce bir ağırlık seçin! (Jungle Bar Lift veya Jungle Squat)",
            Duration = 4
        })
        return
    end
    
    States.FarmActive = true
    local weightData = weightLocations[States.SelectedWeight]
    
    -- İstatistik takibi
    farmStartTime = tick()
    farmStartStrength = getCurrentStrength()
    farmLastStrength = farmStartStrength
    farmPowerPerSecond = 0
    farmRebirthStartTime = tick()
    farmRebirthStartCount = getRebirthCount()
    farmRebirthPerSecond = 0
    lastEggTime = 0
    
    farmStatusLabel.Text = "🟢 Farm başlatılıyor..."
    farmStatusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "⚡ Farm Started!",
        Text = weightData.name .. " seçildi. TANRI HIZI farm başlıyor!",
        Duration = 4
    })
    
    -- ═══════════════════════════════════════════════════════
    -- TIMER LOOP (her saniye güncelle)
    -- ═══════════════════════════════════════════════════════
    spawn(function()
        while States.FarmActive and isSessionAlive() do
            pcall(function()
                local elapsed = tick() - farmStartTime
                farmTimerLabel.Text = "⏱ Süre: " .. formatTime(elapsed)
                
                local eggElapsed = tick() - lastEggTime
                if not States.AutoProteinEgg then
                    farmEggLabel.Text = "🥚 Egg: Kapalı"
                elseif lastEggTime == 0 then
                    farmEggLabel.Text = "🥚 Egg: İlk yumurta yenecek..."
                elseif eggElapsed >= EGG_COOLDOWN then
                    farmEggLabel.Text = "🥚 Egg: Hazır!"
                else
                    local remaining = math.ceil(EGG_COOLDOWN - eggElapsed)
                    farmEggLabel.Text = "🥚 Egg: " .. math.floor(remaining/60) .. "dk " .. (remaining%60) .. "sn"
                end
            end)
            task.wait(1)
        end
    end)
    
    -- Konumları tara
    findWeightPositions()
    
    -- ═══════════════════════════════════════════════════════
    -- 🔥🔥🔥 TANRI HIZI REP SPAM SİSTEMİ 🔥🔥🔥
    -- ═══════════════════════════════════════════════════════
    local repSpamActive = false
    local mySession = farmSessionId -- Bu session'a ait loop'lar sadece bu ID ile çalışır
    
    local function isSessionAlive()
        return States.FarmActive and farmSessionId == mySession
    end
    
    local function startGodRepSpam()
        repSpamActive = true
        globalRepSpamActive = true
        
        -- ═══ HEARTBEAT: Her frame 3 rep + cooldown bypass ═══
        if farmRepConn then pcall(function() farmRepConn:Disconnect() end) end
        farmRepConn = RunService.Heartbeat:Connect(function()
            if not repSpamActive or not globalRepSpamActive or not isSessionAlive() then return end
            pcall(function()
                local e = LP:FindFirstChild("muscleEvent")
                if e then
                    for i = 1, 3 do
                        e:FireServer("rep")
                    end
                end
                -- RepTime sürekli sıfırla (her frame)
                if Character then
                    for _, tool in pairs(Character:GetChildren()) do
                        if tool:IsA("Tool") then
                            local rt = tool:FindFirstChild("repTime")
                            if rt then rt.Value = 0 end
                            local rc = tool:FindFirstChild("repCooldown")
                            if rc then rc.Value = 0 end
                            local lc = tool:FindFirstChild("liftCooldown")
                            if lc then lc.Value = 0 end
                        end
                    end
                end
            end)
        end)
        
        -- ═══ PARALEL LOOP 1: 10 rep / 0.05s ═══
        spawn(function()
            while repSpamActive and globalRepSpamActive and isSessionAlive() do
                pcall(function()
                    local e = LP:FindFirstChild("muscleEvent")
                    if e then
                        for i = 1, 10 do e:FireServer("rep") end
                    end
                end)
                task.wait(0.05)
            end
        end)
        
        -- ═══ PARALEL LOOP 2: 10 rep / 0.05s ═══
        spawn(function()
            while repSpamActive and globalRepSpamActive and isSessionAlive() do
                pcall(function()
                    local e = LP:FindFirstChild("muscleEvent")
                    if e then
                        for i = 1, 10 do e:FireServer("rep") end
                    end
                end)
                task.wait(0.05)
            end
        end)
        
        -- ═══ SÜREKLI COOLDOWN BYPASS ═══
        spawn(function()
            while repSpamActive and globalRepSpamActive and isSessionAlive() do
                pcall(function()
                    if Character then
                        for _, tool in pairs(Character:GetChildren()) do
                            if tool:IsA("Tool") then
                                local rt = tool:FindFirstChild("repTime")
                                if rt then rt.Value = 0 end
                                local rc = tool:FindFirstChild("repCooldown")
                                if rc then rc.Value = 0 end
                                local lc = tool:FindFirstChild("liftCooldown")
                                if lc then lc.Value = 0 end
                            end
                        end
                    end
                    local bp = LP:FindFirstChild("Backpack")
                    if bp then
                        for _, tool in pairs(bp:GetChildren()) do
                            if tool:IsA("Tool") then
                                local rt = tool:FindFirstChild("repTime")
                                if rt then rt.Value = 0 end
                            end
                        end
                    end
                end)
                task.wait(0.1)
            end
        end)
    end
    
    local function stopGodRepSpam()
        repSpamActive = false
        globalRepSpamActive = false
        if farmRepConn then pcall(function() farmRepConn:Disconnect() end); farmRepConn = nil end
    end
    
    -- ═══════════════════════════════════════════════════════
    -- 🔄 ANA FARM DÖNGÜSÜ
    -- ═══════════════════════════════════════════════════════
    spawn(function()
        while States.FarmActive and isSessionAlive() do
            local ok, err = pcall(function()
                
                -- ══════ ADIM 1: IŞINLAN ══════
                farmStatusLabel.Text = "⚡ [1] " .. weightData.name .. " yanına ışınlanıyor..."
                
                if weightData.pos and Character and Character:FindFirstChild("HumanoidRootPart") then
                    Character.HumanoidRootPart.CFrame = CFrame.new(weightData.pos)
                else
                    findWeightPositions()
                    if weightData.pos and Character and Character:FindFirstChild("HumanoidRootPart") then
                        Character.HumanoidRootPart.CFrame = CFrame.new(weightData.pos)
                    end
                end
                task.wait(0.2)
                
                -- ══════ ADIM 2: E TUŞU (ağırlığı al) ══════
                farmStatusLabel.Text = "⚡ [2] E tuşu - ağırlık alınıyor..."
                pressE()
                task.wait(0.2)
                pressE()
                task.wait(0.15)
                
                -- ══════ ADIM 3: SWIFT SAMURAI 8x TAK ══════
                farmStatusLabel.Text = "⚡ [3] Swift Samurai 8x takılıyor..."
                ultraFastPetSwap(States.FarmPetSwiftSamurai, States.FarmSwiftCount)
                task.wait(0.05)
                
                -- Auto Lift aç
                pcall(function()
                    local a = LP:FindFirstChild("autoLiftEnabled")
                    if a then a.Value = true end
                end)
                
                -- ══════ ADIM 4: 🔥 TANRI HIZI GÜÇ KAS 🔥 ══════
                farmStatusLabel.Text = "🔥 [4] TANRI HIZI güç kasılıyor..."
                startGodRepSpam()
                
                -- Rebirth kontrolü döngüsü
                local lastStatUpdate = 0
                while States.FarmActive and isSessionAlive() do
                    local now = tick()
                    
                    -- İstatistikleri 0.5s'de bir güncelle
                    if (now - lastStatUpdate) >= 0.5 then
                        lastStatUpdate = now
                        local str = getCurrentStrength()
                        local req = getRebirthRequirement()
                        local rb = getRebirthCount()
                        
                        local elapsed = now - farmStartTime
                        if elapsed > 1 then
                            farmPowerPerSecond = (str - farmStartStrength) / elapsed
                        end
                        
                        local rbElapsed = now - farmRebirthStartTime
                        local rbDoneCount = rb - farmRebirthStartCount
                        if rbElapsed > 1 and rbDoneCount > 0 then
                            farmRebirthPerSecond = rbDoneCount / rbElapsed
                        end
                        
                        pcall(function()
                            farmStatusLabel.Text = "🔥 Güç: " .. formatNumber(str) .. " / " .. (req > 0 and formatNumber(req) or "?") .. " | Rebirth: " .. tostring(rb)
                            farmRebirthLabel.Text = "🔄 Rebirth: " .. tostring(rb)
                            farmSpeedLabel.Text = "📊 Güç Hızı:\n" ..
                                "  ⏱ Dakikada: " .. formatNumber(farmPowerPerSecond * 60) .. "\n" ..
                                "  ⏰ Saatte: " .. formatNumber(farmPowerPerSecond * 3600) .. "\n" ..
                                "  📅 Günde: " .. formatNumber(farmPowerPerSecond * 86400) .. "\n" ..
                                "  📆 Haftada: " .. formatNumber(farmPowerPerSecond * 604800)
                            farmRebirthSpeedLabel.Text = "⚡ Rebirth Hızı:\n" ..
                                "  ⏱ Dakikada: " .. string.format("%.1f", farmRebirthPerSecond * 60) .. "\n" ..
                                "  ⏰ Saatte: " .. string.format("%.0f", farmRebirthPerSecond * 3600) .. "\n" ..
                                "  📅 Günde: " .. string.format("%.0f", farmRebirthPerSecond * 86400) .. "\n" ..
                                "  📆 Haftada: " .. string.format("%.0f", farmRebirthPerSecond * 604800)
                        end)
                        
                        -- Protein Egg
                        if States.AutoProteinEgg then
                            pcall(function()
                                if eatOneEgg() then
                                    farmEggLabel.Text = "🥚 Egg: Yendi! ✅"
                                end
                            end)
                        end
                    end
                    
                    -- ══════ REBİRTH KONTROLÜ ══════
                    if canRebirth() then
                        -- 1) Rep spam DURDUR
                        stopGodRepSpam()
                        
                        -- 2) Tribal Overlord 8x TAK
                        farmStatusLabel.Text = "🟡 REBIRTH! Tribal Overlord 8x takılıyor..."
                        ultraFastPetSwap(States.FarmPetTribalOverlord, States.FarmTribalCount)
                        task.wait(0.02)
                        
                        -- 3) ANLIK REBIRTH (animasyonsuz)
                        farmStatusLabel.Text = "🟡 FAST REBIRTH ATILIYOR!"
                        
                        -- Animasyon GUI'lerini yok et
                        pcall(function()
                            local pg = LP:FindFirstChild("PlayerGui")
                            if pg then
                                for _, gui in pairs(pg:GetDescendants()) do
                                    pcall(function()
                                        if gui:IsA("Frame") and gui.Name:lower():find("rebirth") then
                                            gui.Visible = false
                                            gui:Destroy()
                                        end
                                    end)
                                end
                            end
                        end)
                        
                        -- 15 rebirth denemesi (en az biri tutar)
                        for attempt = 1, 15 do
                            doRebirth()
                        end
                        task.wait(0.02)
                        
                        -- Animasyon kalıntıları temizle
                        pcall(function()
                            local pg = LP:FindFirstChild("PlayerGui")
                            if pg then
                                for _, gui in pairs(pg:GetDescendants()) do
                                    pcall(function()
                                        if gui:IsA("Frame") and gui.Name:lower():find("rebirth") then
                                            gui.Visible = false
                                            gui:Destroy()
                                        end
                                    end)
                                end
                            end
                        end)
                        
                        -- 4) Güç takibini sıfırla
                        farmStartTime = tick()
                        farmStartStrength = getCurrentStrength()
                        farmPowerPerSecond = 0
                        
                        local newRb = getRebirthCount()
                        pcall(function()
                            farmRebirthLabel.Text = "🔄 Rebirth: " .. tostring(newRb)
                        end)
                        
                        -- 5) Döngüyü kır → başa dön (Swift Samurai takılacak, rep spam başlayacak)
                        break
                    end
                    
                    task.wait(0.05) -- 50ms: rebirth anını kaçırmaz
                end
                
                -- Rep spam temizle (döngü dışında)
                stopGodRepSpam()
                task.wait(0.02)
                
            end)
            
            if not ok then
                warn("[Farm Error] " .. tostring(err))
                task.wait(0.5)
            end
        end
        
        -- Farm tamamen durduğunda temizlik
        stopGodRepSpam()
        stopFarm()
    end)
end

