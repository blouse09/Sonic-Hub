local weightLocations = {
    JungleBarLift = {name = "Jungle Bar Lift", pos = nil, searchNames = {"JungleBarLift", "Jungle Bar Lift", "jungleBarLift"}},
    JungleSquat = {name = "Jungle Squat (En Büyüğü)", pos = nil, searchNames = {"JungleSquat", "Jungle Squat", "jungleSquat"}}
}

-- Workspace'ten ağırlık konumlarını bul (EN BÜYÜĞÜ seç)
local function findWeightPositions()
    pcall(function()
        for key, data in pairs(weightLocations) do
            data.pos = nil
            local bestPos = nil
            local bestY = -math.huge -- En yüksek Y = en büyük ağırlık
            
            for _, obj in pairs(workspace:GetDescendants()) do
                pcall(function()
                    if obj:IsA("BasePart") or obj:IsA("Model") then
                        local objName = obj.Name:lower()
                        -- Sadece "jungle" içeren objelere bak
                        if objName:find("jungle") then
                            for _, sName in ipairs(data.searchNames) do
                                if objName:find(sName:lower()) then
                                    local pos = nil
                                    if obj:IsA("Model") then
                                        local primary = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                                        if primary then
                                            pos = primary.Position
                                        end
                                    else
                                        pos = obj.Position
                                    end
                                    -- En yüksek Y pozisyonlu olanı seç (en büyük ağırlık)
                                    if pos and pos.Y > bestY then
                                        bestY = pos.Y
                                        bestPos = pos + Vector3.new(0, 3, 0)
                                    end
                                    break
                                end
                            end
                        end
                    end
                end)
            end
            
            if bestPos then
                data.pos = bestPos
            end
        end
    end)
end

-- Script başında konumları bul
spawn(function()
    wait(2)
    findWeightPositions()
end)

