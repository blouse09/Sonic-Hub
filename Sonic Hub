local function L(key)
    return Translations[currentLang][key] or Translations["EN"][key] or key
end

local function registerLang(element, key, property)
    table.insert(langElements, {element = element, key = key, property = property or "Text"})
end

local function switchLanguage()
    currentLang = (currentLang == "EN") and "TR" or "EN"
    _G.SonicHubLang = currentLang
    for _, entry in pairs(langElements) do
        pcall(function()
            if entry.isSection then
                entry.element.Text = "━━ " .. L(entry.key) .. " ━━"
            elseif entry.isSlider then
                -- Slider: update base text, keep current value
                local curText = entry.element.Text
                local val = curText:match(": (%d+)$") or ""
                entry.element.Text = L(entry.key) .. ": " .. val
            else
                entry.element[entry.property] = L(entry.key)
            end
        end)
    end
end

local function textToLangKey(text)
    for key, val in pairs(Translations.EN) do
        if val == text then return key end
    end
    return nil
end

