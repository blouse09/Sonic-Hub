local repHookInstalled = false

local function installRepBoostHook()
    if repHookInstalled then return true end
    local ok = pcall(function()
        local gf = require(RS:WaitForChild("globalFunctions", 5))
        if not gf then return end

        local orig = gf.calculatePetRepTimeBoost
        if not orig then return end

        gf.calculatePetRepTimeBoost = function(player)
            if States.RepBoostAllPets then
                local eq = player:FindFirstChild("equippedPets")
                if eq then
                    local count = 0
                    for _, p in pairs(eq:GetChildren()) do
                        if p and p.Value and p.Value.Parent then
                            if player.Character and p.Value.Parent == player.Character then
                                count = count + 1
                            end
                        end
                    end
                    if count == 0 then count = 1 end
                    return (count * States.RepBoostMultiplier) / 100
                end
                return States.RepBoostMultiplier / 100
            end
            return orig(player)
        end
        repHookInstalled = true
    end)
    return ok and repHookInstalled
end

spawn(function()
    wait(1)
    installRepBoostHook()
end)

