------------------------------------------------------------
local function getCurrentStrength()
    local strength = 0
    pcall(function()
        -- leaderstats'tan oku
        local ls = LP:FindFirstChild("leaderstats")
        if ls then
            local s = ls:FindFirstChild("Strength") or ls:FindFirstChild("strength") or ls:FindFirstChild("Power") or ls:FindFirstChild("power")
            if s then strength = s.Value or 0 end
        end
        -- hiddenStats'tan oku (alternatif)
        if strength == 0 then
            local hs = LP:FindFirstChild("hiddenStats")
            if hs then
                local s = hs:FindFirstChild("strength") or hs:FindFirstChild("Strength") or hs:FindFirstChild("muscleSize")
                if s then strength = s.Value or 0 end
            end
        end
        -- Diğer lokasyonlar
        if strength == 0 then
            local s = LP:FindFirstChild("strength") or LP:FindFirstChild("Strength") or LP:FindFirstChild("muscleSize")
            if s and s:IsA("ValueBase") then strength = s.Value or 0 end
        end
    end)
    return strength
end

local function getRebirthRequirement()
    local req = 0
    pcall(function()
        -- hiddenStats'tan oku
        local hs = LP:FindFirstChild("hiddenStats")
        if hs then
            local rs = hs:FindFirstChild("rebirthStrength") or hs:FindFirstChild("rebirthRequirement") or hs:FindFirstChild("rebirthCost") or hs:FindFirstChild("requiredStrength")
            if rs then req = rs.Value or 0 end
        end
        -- Player altında direkt
        if req == 0 then
            local possibleNames = {"rebirthStrength", "rebirthRequirement", "rebirthCost", "requiredStrength", "nextRebirthStrength"}
            for _, name in ipairs(possibleNames) do
                local rs = LP:FindFirstChild(name)
                if rs and rs:IsA("ValueBase") then
                    req = rs.Value or 0
                    if req > 0 then break end
                end
            end
        end
        -- leaderstats altında
        if req == 0 then
            local ls = LP:FindFirstChild("leaderstats")
            if ls then
                local rs = ls:FindFirstChild("RebirthReq") or ls:FindFirstChild("ReqStrength")
                if rs then req = rs.Value or 0 end
            end
        end
    end)
    return req
end

local function canRebirth()
    local strength = getCurrentStrength()
    local req = getRebirthRequirement()
    if req > 0 then
        return strength >= req
    end
    -- Requirement bulunamazsa, rebirth denemek yerine false dön
    -- (Sonsuz rebirth spam'ini engelle)
    return false
end

local function getRebirthCount()
    local count = 0
    pcall(function()
        local ls = LP:FindFirstChild("leaderstats")
        if ls then
            local rb = ls:FindFirstChild("Rebirths") or ls:FindFirstChild("Rebirth") or ls:FindFirstChild("rebirths")
            if rb then count = rb.Value or 0 end
        end
        if count == 0 then
            local hs = LP:FindFirstChild("hiddenStats")
            if hs then
                local rb = hs:FindFirstChild("rebirths") or hs:FindFirstChild("Rebirths")
                if rb then count = rb.Value or 0 end
            end
        end
    end)
    return count
end

local function doRebirth()
    local success = false
    pcall(function()
        local rEvents = RS:FindFirstChild("rEvents")
        if rEvents then
            -- Birden fazla remote ismi dene
            local remoteNames = {"rebirthRemote", "rebirthEvent", "rebirth", "Rebirth", "rebirthRemoteEvent"}
            for _, rName in ipairs(remoteNames) do
                local rebirthRemote = rEvents:FindFirstChild(rName)
                if rebirthRemote then
                    -- Birden fazla argument varyasyonu dene
                    local args = {"rebirthRequest", "rebirth", "Rebirth", "doRebirth", "requestRebirth"}
                    for _, arg in ipairs(args) do
                        pcall(function()
                            if rebirthRemote:IsA("RemoteFunction") then
                                rebirthRemote:InvokeServer(arg)
                            elseif rebirthRemote:IsA("RemoteEvent") then
                                rebirthRemote:FireServer(arg)
                            end
                        end)
                    end
                    -- Argsız da dene
                    pcall(function()
                        if rebirthRemote:IsA("RemoteFunction") then
                            rebirthRemote:InvokeServer()
                        elseif rebirthRemote:IsA("RemoteEvent") then
                            rebirthRemote:FireServer()
                        end
                    end)
                    success = true
                    break
                end
            end
        end
        -- Player altındaki rebirth event'i de dene
        if not success then
            local pEvent = LP:FindFirstChild("rebirthRemote") or LP:FindFirstChild("rebirthEvent") or LP:FindFirstChild("muscleEvent")
            if pEvent then
                pcall(function()
                    if pEvent:IsA("RemoteEvent") then
                        pEvent:FireServer("rebirth")
                        pEvent:FireServer("rebirthRequest")
                    elseif pEvent:IsA("RemoteFunction") then
                        pEvent:InvokeServer("rebirth")
                        pEvent:InvokeServer("rebirthRequest")
                    end
                end)
                success = true
            end
        end
    end)
    return success
end

