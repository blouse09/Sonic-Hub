-- ═══ Xeno & Delta uyumlu HTTP ═══
local function safeHttpGet(url)
    local ok1, res1 = pcall(function() return game:HttpGet(url) end)
    if ok1 and res1 then return res1 end
    local ok2, res2 = pcall(function() return request({Url = url, Method = "GET"}).Body end)
    if ok2 and res2 then return res2 end
    local ok3, res3 = pcall(function() return http_request({Url = url, Method = "GET"}).Body end)
    if ok3 and res3 then return res3 end
    local ok4, res4 = pcall(function() return syn.request({Url = url, Method = "GET"}).Body end)
    if ok4 and res4 then return res4 end
    local ok5, res5 = pcall(function() return HttpService:GetAsync(url) end)
    if ok5 and res5 then return res5 end
    local ok6, res6 = pcall(function() return httpget(url) end)
    if ok6 and res6 then return res6 end
    return nil
end

