FastRebTab:CreateSection("Time & Pace")
local timeLabel = FastRebTab:CreateLabel("0d 0h 0m 0s - Inactive")
local paceLabel = FastRebTab:CreateLabel("Pace: 0/Hr | 0/Day | 0/Wk")
local avgPaceLabel = FastRebTab:CreateLabel("Avg: 0/Hr | 0/Day | 0/Wk")
local rbStatsLabel = FastRebTab:CreateLabel("Rebirths: "..formatNumber(rebirthsStat.Value).." | Gained: 0")

local lastRbTime = tick()
local lastRbValue = rebirthsStat.Value
local paceHH, paceDD, paceWW = {}, {}, {}
local maxHist = 20
local rbCount = 0

local function updateRbLabel()
    local gained = rebirthsStat.Value - initialRebirths
    rbStatsLabel:Set(string.format("Rebirths: %s | Gained: %s", formatNumber(rebirthsStat.Value), formatNumber(gained)))
end

local function calcPace()
    rbCount = rbCount + 1
    if rbCount < 2 then
        lastRbTime = tick()
        lastRbValue = rebirthsStat.Value
        return
    end
    local now = tick()
    local gained = rebirthsStat.Value - lastRbValue
    if gained > 0 then
        local avgT = (now - lastRbTime) / gained
        local pH, pD, pW = 3600/avgT, 86400/avgT, 604800/avgT
        paceLabel:Set(string.format("Pace: %s/Hr | %s/Day | %s/Wk", formatNumber(pH), formatNumber(pD), formatNumber(pW)))
        table.insert(paceHH, pH); table.insert(paceDD, pD); table.insert(paceWW, pW)
        if #paceHH > maxHist then
            table.remove(paceHH, 1); table.remove(paceDD, 1); table.remove(paceWW, 1)
        end
        local function avg(t) local s=0; for _,v in ipairs(t) do s=s+v end; return #t>0 and s/#t or 0 end
        avgPaceLabel:Set(string.format("Avg: %s/Hr | %s/Day | %s/Wk", formatNumber(avg(paceHH)), formatNumber(avg(paceDD)), formatNumber(avg(paceWW))))
        lastRbTime = now
        lastRbValue = rebirthsStat.Value
    end
end

local function updateUI()
    local now = tick()
    local el = isRunning and (now - rbStartTime + totalElapsed) or totalElapsed
    timeLabel:Set(string.format("%dd %dh %dm %ds - %s", math.floor(el/86400), math.floor((el%86400)/3600), math.floor((el%3600)/60), math.floor(el%60), isRunning and "Rebirthing" or "Paused"))
end

rebirthsStat:GetPropertyChangedSignal("Value"):Connect(function()
    calcPace()
    updateRbLabel()
end)

-- Pet management
local function managePets(petName)
    for _, folder in pairs(player.petsFolder:GetChildren()) do
        if folder:IsA("Folder") then
            for _, pet in pairs(folder:GetChildren()) do
                replicatedStorage.rEvents.equipPetEvent:FireServer("unequipPet", pet)
            end
        end
    end
    task.wait(0.1)
    for _, pet in pairs(player.petsFolder.Unique:GetChildren()) do
        if pet.Name == petName then
            replicatedStorage.rEvents.equipPetEvent:FireServer("equipPet", pet)
        end
    end
end

local function doRebirth()
    local rebirths = rebirthsStat.Value
    local target = 5000 + (rebirths * 2550)
    while isRunning and player.leaderstats.Strength.Value < target do
        local reps = player.MembershipType == Enum.MembershipType.Premium and 8 or 14
        for _ = 1, reps do muscleEvent:FireServer("rep") end
        task.wait(0.02)
    end
    if isRunning and player.leaderstats.Strength.Value >= target then
        managePets("Tribal Overlord")
        task.wait(0.25)
        local before = rebirthsStat.Value
        repeat
            replicatedStorage.rEvents.rebirthRemote:InvokeServer("rebirthRequest")
            task.wait(0.05)
        until rebirthsStat.Value > before or not isRunning
    end
end

local function fastRebirthLoop()
    while isRunning do
        managePets("Swift Samurai")
        doRebirth()
        task.wait(0.5)
    end
end

