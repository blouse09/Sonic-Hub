local FarmTab = Window:CreateTab("Fast Farm")

local strengthStat = leaderstats:WaitForChild("Strength")
local durabilityStat = player:WaitForChild("Durability")

local function fmtN(n)
    local neg = n < 0; n = math.abs(n)
    local prefix = neg and "-" or ""
    if n >= 1e15 then return prefix..string.format("%.2fQ", n/1e15)
    elseif n >= 1e12 then return prefix..string.format("%.2fT", n/1e12)
    elseif n >= 1e9 then return prefix..string.format("%.2fB", n/1e9)
    elseif n >= 1e6 then return prefix..string.format("%.2fM", n/1e6)
    elseif n >= 1e3 then return prefix..string.format("%.2fK", n/1e3)
    else return prefix..string.format("%.2f", n) end
end

FarmTab:CreateSection("Pace Tracking")
local swLabel = FarmTab:CreateLabel("0d 0h 0m 0s - Inactive")
local pStrLabel = FarmTab:CreateLabel("Str Pace: 0/Hr | 0/Day | 0/Wk")
local pDurLabel = FarmTab:CreateLabel("Dur Pace: 0/Hr | 0/Day | 0/Wk")
local aStrLabel = FarmTab:CreateLabel("Avg Str: 0/Hr | 0/Day | 0/Wk")
local aDurLabel = FarmTab:CreateLabel("Avg Dur: 0/Hr | 0/Day | 0/Wk")

FarmTab:CreateSection("Stats")
local strLabel = FarmTab:CreateLabel("Strength: 0 | Gained: 0")
local durLabel = FarmTab:CreateLabel("Durability: 0 | Gained: 0")

local fStart = 0
local pausedEl = 0
local runFR = false
local tracking = false
local sH, dH = {}, {}
local cInt = 10
local iStr = strengthStat.Value
local iDur = durabilityStat.Value

task.spawn(function()
    local lastC = tick()
    while true do
        local now = tick()
        local cS = strengthStat.Value
        local cD = durabilityStat.Value
        strLabel:Set("Strength: "..fmtN(cS).." | Gained: "..fmtN(cS - iStr))
        durLabel:Set("Durability: "..fmtN(cD).." | Gained: "..fmtN(cD - iDur))
        if runFR then
            if not tracking then
                tracking = true; fStart = now; sH = {}; dH = {}
            end
            local el = pausedEl + (now - fStart)
            swLabel:Set(string.format("%dd %dh %dm %ds - Running", math.floor(el/86400), math.floor((el%86400)/3600), math.floor((el%3600)/60), math.floor(el%60)))
            table.insert(sH, {time=now, value=cS})
            table.insert(dH, {time=now, value=cD})
            while #sH > 0 and now - sH[1].time > cInt do table.remove(sH, 1) end
            while #dH > 0 and now - dH[1].time > cInt do table.remove(dH, 1) end
            if now - lastC >= cInt then
                lastC = now
                if #sH >= 2 then
                    local sps = (sH[#sH].value - sH[1].value) / cInt
                    pStrLabel:Set("Str Pace: "..fmtN(sps*3600).."/Hr | "..fmtN(sps*86400).."/Day | "..fmtN(sps*604800).."/Wk")
                end
                if #dH >= 2 then
                    local dps = (dH[#dH].value - dH[1].value) / cInt
                    pDurLabel:Set("Dur Pace: "..fmtN(dps*3600).."/Hr | "..fmtN(dps*86400).."/Day | "..fmtN(dps*604800).."/Wk")
                end
                local tE = pausedEl + (now - fStart)
                if tE > 0 then
                    local as = (cS - iStr)/tE; local ad = (cD - iDur)/tE
                    aStrLabel:Set("Avg Str: "..fmtN(as*3600).."/Hr | "..fmtN(as*86400).."/Day | "..fmtN(as*604800).."/Wk")
                    aDurLabel:Set("Avg Dur: "..fmtN(ad*3600).."/Hr | "..fmtN(ad*86400).."/Day | "..fmtN(ad*604800).."/Wk")
                end
            end
        else
            if tracking then
                tracking = false; pausedEl = pausedEl + (now - fStart)
                local pe = pausedEl
                swLabel:Set(string.format("%dd %dh %dm %ds - Stopped", math.floor(pe/86400), math.floor((pe%86400)/3600), math.floor((pe%3600)/60), math.floor(pe%60)))
                pStrLabel:Set("Str Pace: 0/Hr | 0/Day | 0/Wk")
                pDurLabel:Set("Dur Pace: 0/Hr | 0/Day | 0/Wk")
                aStrLabel:Set("Avg Str: 0/Hr | 0/Day | 0/Wk")
                aDurLabel:Set("Avg Dur: 0/Hr | 0/Day | 0/Wk")
                sH = {}; dH = {}
            end
        end
        task.wait(0.05)
    end
end)

