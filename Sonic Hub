local function showPlayerStats(plr)
    local info = "👤 " .. plr.Name .. " (" .. plr.DisplayName .. ")\n"
    pcall(function()
        local ls = plr:FindFirstChild("leaderstats")
        if ls then
            for _, s in pairs(ls:GetChildren()) do
                info = info .. "⚡ " .. s.Name .. ": " .. tostring(s.Value) .. "\n"
            end
        end
    end)
    pcall(function()
        local extraVals = {"Rebirths","rebirths","Strength","strength","Diamonds","diamonds","Gems","gems","Kills","kills","Wins","wins","muscleSize","punchPower","goodKarma","badKarma","goodKills","badKills","karma","Karma"}
        for _, vName in ipairs(extraVals) do
            local v = plr:FindFirstChild(vName)
            if v and v:IsA("ValueBase") then
                local icon = "💎"
                if vName:lower():find("good") then icon = "😇" end
                if vName:lower():find("bad") then icon = "😈" end
                if vName:lower():find("karma") then icon = "⚖" end
                if vName:lower():find("kill") then icon = "💀" end
                info = info .. icon .. " " .. vName .. ": " .. tostring(v.Value) .. "\n"
            elseif v and v:IsA("Folder") then
                info = info .. "📁 " .. vName .. ": " .. #v:GetChildren() .. "\n"
            end
        end
    end)
    pcall(function()
        local pf = plr:FindFirstChild("petsFolder")
        if pf then
            local count = 0
            for _, r in pairs(pf:GetChildren()) do
                if r:IsA("Folder") then count = count + #r:GetChildren() end
            end
            info = info .. "🐾 Total Pets: " .. count .. "\n"
        end
    end)
    statsInfoLabel.Text = info
end

